{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "numberOfRuns": 3,
      "autodiscoverUrlBlocklist": ["waitlist-confirmed", "/404"]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9, "aggregationMethod": "median" }]
      }
    }
  }
}
