{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "autodiscoverUrlBlocklist": ["waitlist-confirmed"]
    },
    "assert": {
      "assertMatrix": [
        {
          "matchingUrlPattern": ".*",
          "assertions": {
            "categories:accessibility": ["error", { "minScore": 0.9 }],
            "categories:best-practices": ["warn", { "minScore": 0.9 }],
            "categories:performance": ["warn", { "minScore": 0.9 }]
          }
        },
        {
          "matchingUrlPattern": "^https?://[^/]+/index\\.html$",
          "assertions": {
            "categories:seo": ["error", { "minScore": 0.9 }]
          }
        }
      ]
    }
  }
}
