---
import Layout from "../layouts/Layout.astro";

const appUrl = import.meta.env.PUBLIC_APP_URL || "https://app.useorbit.org";
---

<Layout>
  <!-- Header -->
  <header id="site-header" class="header-blur fixed top-0 left-0 right-0 z-50 border-b border-transparent">
    <nav class="max-w-6xl mx-auto px-5 sm:px-8 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5">
        <img src="/logo.png" alt="Orbit" class="w-8 h-8 rounded-lg" />
        <span class="text-xl font-bold text-text-primary">Orbit</span>
      </a>
      <div class="flex items-center gap-3">
        <!-- Language Switcher -->
        <button
          id="lang-toggle"
          class="text-sm text-text-secondary hover:text-text-primary transition-colors px-3 py-1.5 rounded-xl border border-border hover:border-text-muted"
          aria-label="Switch language"
        >
          <span id="lang-label">EN</span>
        </button>
        <a
          href={appUrl}
          class="btn-glow bg-primary hover:bg-primary-hover text-white font-semibold px-5 py-2 rounded-3xl text-sm transition-colors"
          data-i18n="header.cta"
        >
          Go to Orbit
        </a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero-gradient relative min-h-screen flex items-center pt-16">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=%2260%22 height=%2260%22 viewBox=%220 0 60 60%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cg fill=%22none%22 fill-rule=%22evenodd%22%3E%3Cg fill=%22%23ffffff%22%3E%3Cpath d=%22M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z%22/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>

      <div class="max-w-6xl mx-auto px-5 sm:px-8 w-full">
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
          <div class="fade-in-section text-center lg:text-left">
            <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-tight tracking-tight">
              <span data-i18n="hero.title1">Build Better Habits,</span>
              <span class="gradient-text" data-i18n="hero.title2">One Day at a Time</span>
            </h1>
            <p class="mt-6 text-lg sm:text-xl text-text-secondary leading-relaxed max-w-xl mx-auto lg:mx-0" data-i18n="hero.subtitle">
              Track your daily habits, build streaks, and get AI-powered insights to stay on top of your goals.
            </p>
            <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
              <a
                href={appUrl}
                class="btn-glow bg-primary hover:bg-primary-hover text-white font-semibold px-8 py-3.5 rounded-3xl text-base transition-colors inline-flex items-center justify-center gap-2"
              >
                <span data-i18n="hero.cta">Get Started</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </a>
              <div class="tooltip-trigger flex sm:inline-flex">
                <a
                  href="#"
                  class="border border-border hover:border-text-muted text-text-secondary font-semibold px-8 py-3.5 rounded-3xl text-base transition-colors inline-flex items-center justify-center gap-2.5 cursor-default opacity-70 w-full sm:w-auto"
                  onclick="return false;"
                >
                  <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 3.658L16.8 9.99l-2.302 2.302L5.864 3.658z"/>
                  </svg>
                  <span data-i18n="hero.android">Download for Android</span>
                </a>
                <span class="tooltip-text" data-i18n="hero.comingSoon">Coming Soon</span>
              </div>
            </div>
          </div>

          <!-- Phone Mockup -->
          <div class="fade-in-section flex justify-center lg:justify-end">
            <div class="relative">
              <div class="phone-glow p-[2px] rounded-[3rem] shadow-2xl shadow-primary/20">
                <div class="phone-frame rounded-[2.9rem] w-[280px] sm:w-[300px]">
                  <div class="app-screen-scaler">
                    <div class="app-screen">
                      <!-- Status Bar -->
                      <div class="app-statusbar">
                        <span>9:41</span>
                        <div class="app-statusbar-right">
                          <div class="app-signal"><span></span><span></span><span></span><span></span></div>
                          <span style="font-size:11px">5G</span>
                          <div class="app-battery"><div class="app-battery-fill"></div></div>
                        </div>
                      </div>

                      <!-- Header -->
                      <div class="app-hdr">
                        <div class="app-hdr-left">
                          <img class="app-hdr-logo" src="/logo.png" alt="Orbit">
                          <span class="app-hdr-title">Orbit</span>
                        </div>
                        <div class="app-hdr-bell">
                          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        </div>
                      </div>

                      <!-- Tabs -->
                      <div class="app-tabs">
                        <div class="app-tab active" data-i18n="mockup.today">Today</div>
                        <div class="app-tab" data-i18n="mockup.allHabits">All Habits</div>
                      </div>

                      <!-- Date Nav -->
                      <div class="app-datenav">
                        <div class="app-datenav-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg></div>
                        <span class="app-datenav-label" data-i18n="mockup.todayLabel">Today</span>
                        <div class="app-datenav-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></div>
                      </div>

                      <!-- AI Card -->
                      <div class="app-ai">
                        <div class="app-ai-hdr">
                          <span class="app-ai-icon">&#10024;</span>
                          <span class="app-ai-title" data-i18n="mockup.yourDay">Your Day</span>
                          <span class="app-pro">PRO</span>
                        </div>
                        <div class="app-ai-body" data-i18n="mockup.aiText">Great momentum! You've completed 3 of 7 habits. Your morning routine streak is at 12 days.</div>
                      </div>

                      <!-- Habit List -->
                      <div class="app-habits">
                        <!-- Morning Routine (with sub-habits, progress ring) -->
                        <div class="app-habit due">
                          <div class="app-expand"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></div>
                          <div class="app-ring">
                            <svg viewBox="0 0 28 28"><circle class="ring-bg" cx="14" cy="14" r="11"/><circle class="ring-fg" cx="14" cy="14" r="11" stroke-dasharray="69.1" stroke-dashoffset="23"/></svg>
                            <span class="app-ring-text">2/3</span>
                          </div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit1">Morning Routine</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">7:00 AM</span>
                              <span class="app-tag" style="background:#f59e0b" data-i18n="mockup.tag.wellness">Wellness</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <!-- Sub-habits -->
                        <div class="app-sub">
                          <div class="app-sub-btn checked"><svg style="width:11px;height:11px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent"><div class="app-sub-name striked" data-i18n="mockup.sub1">Stretch (10 min)</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>
                        <div class="app-sub">
                          <div class="app-sub-btn checked"><svg style="width:11px;height:11px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent"><div class="app-sub-name striked" data-i18n="mockup.sub2">Healthy breakfast</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>
                        <div class="app-sub">
                          <div class="app-sub-btn"></div>
                          <div class="app-hcontent"><div class="app-sub-name" data-i18n="mockup.sub3">Journal (5 min)</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>

                        <!-- Exercise (completed) -->
                        <div class="app-habit done">
                          <div class="app-logbtn checked"><svg style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent">
                            <div class="app-hname striked" data-i18n="mockup.habit2">Exercise</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">8:30 AM</span>
                              <span class="app-checklist-badge">&#9745; 4/4</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <!-- Read 30 minutes -->
                        <div class="app-habit due">
                          <div class="app-logbtn"></div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit3">Read 30 minutes</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">2:00 PM</span>
                              <span class="app-tag" style="background:#3b82f6" data-i18n="mockup.tag.growth">Growth</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <!-- Meditate -->
                        <div class="app-habit due">
                          <div class="app-logbtn"></div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit4">Meditate</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">6:00 PM</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>
                      </div>

                      <!-- Bottom Nav -->
                      <div class="app-nav">
                        <div class="app-nav-inner">
                          <div class="app-nav-item">
                            <svg class="app-nav-icon active" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                            <span class="app-nav-lbl active" data-i18n="mockup.nav.habits">Habits</span>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.chat">Chat</span>
                          </div>
                          <div class="app-fab-wrap">
                            <div class="app-fab"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.calendar">Calendar</span>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.profile">Profile</span>
                          </div>
                        </div>
                      </div>
                      <div class="app-homebar"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
        <svg class="w-5 h-5 text-text-muted" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-24 sm:py-32">
      <div class="max-w-6xl mx-auto px-5 sm:px-8">
        <div class="fade-in-section text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
            <span data-i18n="features.title1">Everything you need to build</span>
            <span class="gradient-text" data-i18n="features.title2">lasting habits</span>
          </h2>
          <p class="mt-4 text-text-secondary text-lg max-w-2xl mx-auto" data-i18n="features.subtitle">
            Simple yet powerful tools designed to help you stick to your routines and see real progress.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
          <div class="fade-in-section feature-card bg-surface border border-border rounded-3xl p-7">
            <div class="w-12 h-12 rounded-2xl bg-primary/10 flex items-center justify-center text-2xl mb-5">&#128197;</div>
            <h3 class="text-lg font-bold text-text-primary mb-2" data-i18n="features.scheduling.title">Smart Scheduling</h3>
            <p class="text-text-secondary text-sm leading-relaxed" data-i18n="features.scheduling.desc">Set daily, weekly, or custom frequencies. Orbit calculates exactly when each habit is due.</p>
          </div>
          <div class="fade-in-section feature-card bg-surface border border-border rounded-3xl p-7">
            <div class="w-12 h-12 rounded-2xl bg-orange-500/10 flex items-center justify-center text-2xl mb-5">&#128293;</div>
            <h3 class="text-lg font-bold text-text-primary mb-2" data-i18n="features.streaks.title">Streak Tracking</h3>
            <p class="text-text-secondary text-sm leading-relaxed" data-i18n="features.streaks.desc">Watch your streaks grow. Visual progress that keeps you motivated day after day.</p>
          </div>
          <div class="fade-in-section feature-card bg-surface border border-border rounded-3xl p-7">
            <div class="w-12 h-12 rounded-2xl bg-blue-500/10 flex items-center justify-center text-2xl mb-5">&#129302;</div>
            <h3 class="text-lg font-bold text-text-primary mb-2" data-i18n="features.ai.title">AI Insights</h3>
            <p class="text-text-secondary text-sm leading-relaxed" data-i18n="features.ai.desc">Get personalized daily summaries and routine analysis powered by AI.</p>
          </div>
          <div class="fade-in-section feature-card bg-surface border border-border rounded-3xl p-7">
            <div class="w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center text-2xl mb-5">&#127793;</div>
            <h3 class="text-lg font-bold text-text-primary mb-2" data-i18n="features.subhabits.title">Sub-Habits</h3>
            <p class="text-text-secondary text-sm leading-relaxed" data-i18n="features.subhabits.desc">Break big habits into smaller steps. Complete sub-tasks to build momentum.</p>
          </div>
          <div class="fade-in-section feature-card bg-surface border border-border rounded-3xl p-7">
            <div class="w-12 h-12 rounded-2xl bg-pink-500/10 flex items-center justify-center text-2xl mb-5">&#128200;</div>
            <h3 class="text-lg font-bold text-text-primary mb-2" data-i18n="features.calendar.title">Calendar View</h3>
            <p class="text-text-secondary text-sm leading-relaxed" data-i18n="features.calendar.desc">See your entire month at a glance with a heatmap of your habit completions.</p>
          </div>
          <div class="fade-in-section feature-card bg-surface border border-border rounded-3xl p-7">
            <div class="w-12 h-12 rounded-2xl bg-cyan-500/10 flex items-center justify-center text-2xl mb-5">&#127760;</div>
            <h3 class="text-lg font-bold text-text-primary mb-2" data-i18n="features.language.title">Multi-Language</h3>
            <p class="text-text-secondary text-sm leading-relaxed" data-i18n="features.language.desc">Available in English and Portuguese. More languages coming soon.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Platforms Section -->
    <section id="platforms" class="py-24 sm:py-32 border-t border-border">
      <div class="max-w-6xl mx-auto px-5 sm:px-8">
        <div class="fade-in-section text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold tracking-tight">
            <span data-i18n="platforms.title1">Available</span>
            <span class="gradient-text" data-i18n="platforms.title2">everywhere</span>
            <span data-i18n="platforms.title3">you are</span>
          </h2>
          <p class="mt-4 text-text-secondary text-lg" data-i18n="platforms.subtitle">Access your habits from any device, anytime.</p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6 max-w-3xl mx-auto">
          <div class="fade-in-section platform-card bg-surface border border-border rounded-3xl p-8 flex flex-col">
            <div class="w-14 h-14 rounded-2xl bg-primary/10 flex items-center justify-center text-3xl mb-6">&#128421;</div>
            <h3 class="text-xl font-bold text-text-primary mb-2" data-i18n="platforms.web.title">Web App</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-8 flex-1" data-i18n="platforms.web.desc">Access Orbit from any browser. Your habits sync across all your devices.</p>
            <a href={appUrl} class="btn-glow bg-primary hover:bg-primary-hover text-white font-semibold px-6 py-3 rounded-3xl text-sm transition-colors inline-flex items-center justify-center gap-2 w-full">
              <span data-i18n="platforms.web.cta">Open Web App</span>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" /></svg>
            </a>
          </div>
          <div class="fade-in-section platform-card bg-surface border border-border rounded-3xl p-8 flex flex-col">
            <div class="flex items-start justify-between mb-6">
              <div class="w-14 h-14 rounded-2xl bg-green-500/10 flex items-center justify-center text-3xl">&#128241;</div>
              <span class="bg-primary/10 text-primary text-xs font-semibold px-3 py-1 rounded-full" data-i18n="hero.comingSoon">Coming Soon</span>
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-2">Android</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-8 flex-1" data-i18n="platforms.android.desc">Take Orbit with you. Track habits on the go with our native Android app.</p>
            <button disabled class="bg-surface border border-border text-text-muted font-semibold px-6 py-3 rounded-3xl text-sm inline-flex items-center justify-center gap-2.5 w-full cursor-not-allowed">
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 3.658L16.8 9.99l-2.302 2.302L5.864 3.658z"/></svg>
              Google Play
            </button>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-24 sm:py-32 relative overflow-hidden">
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="w-[600px] h-[600px] bg-primary/5 rounded-full blur-3xl"></div>
      </div>
      <div class="fade-in-section relative max-w-3xl mx-auto px-5 sm:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold tracking-tight">
          <span data-i18n="cta.title1">Ready to build</span>
          <span class="gradient-text" data-i18n="cta.title2">better habits</span><span data-i18n="cta.title3">?</span>
        </h2>
        <p class="mt-5 text-text-secondary text-lg sm:text-xl max-w-xl mx-auto" data-i18n="cta.subtitle">Join Orbit today and start tracking your progress.</p>
        <div class="mt-10">
          <a href={appUrl} class="btn-glow bg-primary hover:bg-primary-hover text-white font-bold px-10 py-4 rounded-3xl text-lg transition-colors inline-flex items-center justify-center gap-2">
            <span data-i18n="cta.button">Get Started Free</span>
