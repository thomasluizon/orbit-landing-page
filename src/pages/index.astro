---
import Layout from "../layouts/Layout.astro";
import NeonCard from "../components/NeonCard.astro";
import CtaButton from "../components/CtaButton.astro";
import Sparkles from "../components/Sparkles.astro";
import { Image } from "astro:assets";
import logo from "../assets/logo.png";

const appUrl = import.meta.env.PUBLIC_APP_URL || "https://app.useorbit.org";

const heroSparkles = [
  { top: "12%", left: "8%" },
  { top: "22%", left: "24%", sm: true },
  { top: "7%", left: "52%" },
  { top: "18%", left: "78%", sm: true },
  { top: "55%", left: "90%" },
  { top: "70%", left: "6%", sm: true },
  { top: "82%", left: "38%" },
  { top: "40%", left: "96%", sm: true },
];

const dualSectionSparkles = [
  { top: "2%", left: "6%" },
  { top: "6%", left: "20%", sm: true },
  { top: "4%", left: "38%", hideMobile: true },
  { top: "9%", left: "54%", sm: true, hideMobile: true },
  { top: "3%", left: "73%" },
  { top: "8%", left: "88%", sm: true },
  { top: "15%", left: "3%" },
  { top: "20%", left: "27%", sm: true },
  { top: "18%", left: "82%" },
  { top: "25%", left: "12%", sm: true },
  { top: "28%", left: "91%" },
  { top: "32%", left: "64%", sm: true },
  { top: "37%", left: "5%" },
  { top: "42%", left: "45%", sm: true },
  { top: "46%", left: "78%" },
  { top: "50%", left: "15%", sm: true },
  { top: "54%", left: "58%" },
  { top: "58%", left: "32%", sm: true },
  { top: "62%", left: "87%" },
  { top: "68%", left: "7%", sm: true },
  { top: "72%", left: "48%" },
  { top: "76%", left: "22%", sm: true },
  { top: "80%", left: "70%" },
  { top: "85%", left: "36%", sm: true },
  { top: "88%", left: "92%" },
  { top: "93%", left: "60%", sm: true },
  { top: "96%", left: "14%" },
];
---

<Layout>
  <!-- Skip to Content -->
  <a href="#main-content" class="skip-to-content">Skip to content</a>

  <!-- Scroll Progress -->
  <div id="scroll-progress" class="scroll-progress" aria-hidden="true"></div>

  <!-- Header -->
  <header id="site-header" class="header-glass fixed top-0 left-0 right-0 z-50">
    <nav aria-label="Main" class="page-container h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group logo-hover">
        <Image src={logo} alt="Orbit" width={32} height={32} fetchpriority="high" class="w-8 h-8 rounded-lg transition-all group-hover:drop-shadow-[0_0_8px_rgba(139,92,246,0.4)]" />
        <span class="text-lg font-bold text-text-primary">Orbit</span>
      </a>
      <div class="flex items-center gap-5">
        <button
          id="lang-toggle"
          class="text-sm text-text-muted hover:text-text-primary transition-colors cursor-pointer min-w-[44px] min-h-[44px] flex items-center justify-center"
          aria-label="Switch to Portuguese"
        >
          <span id="lang-label" class="border-b border-text-muted/30 pb-0.5">EN</span>
        </button>
        <a
          href={appUrl}
          class="text-sm font-semibold px-5 py-2 rounded-full border border-primary/30 text-primary hover:bg-primary hover:text-white transition-all duration-300"
          data-i18n="header.cta"
        >
          Get Started
        </a>
      </div>
    </nav>
  </header>

  <main id="main-content">
    <!-- Hero Section -->
    <section class="hero-section relative lg:min-h-screen lg:flex lg:items-center pt-16 pb-8 sm:pb-16">
      <!-- Hero Background Layers -->
      <div aria-hidden="true">
      <div class="hero-bg-layer hero-bg-dot-grid"></div>
      <div class="hero-bg-layer hero-glow-primary"></div>
      <div class="hero-bg-layer hero-glow-secondary"></div>
      <div class="hero-bg-layer hero-light-beam"></div>
      <div class="hero-bg-layer hero-vignette-bottom"></div>
      <!-- Hero sparkle stars -->
      <Sparkles sparkles={heroSparkles} />
      <!-- Large diffuse orbs -->
      <div class="hero-orb-large" style="width:260px;height:260px;top:10%;left:5%;--orb-opacity:0.10;--drift-x:20px;--drift-y:-30px;--orb-dur:14s;--orb-delay:0s"></div>
      <div class="hero-orb-large" style="width:200px;height:200px;top:55%;left:2%;--orb-opacity:0.08;--drift-x:-15px;--drift-y:25px;--orb-dur:18s;--orb-delay:2s"></div>
      <div class="hero-orb-large" style="width:180px;height:180px;top:5%;left:65%;--orb-opacity:0.09;--drift-x:18px;--drift-y:-20px;--orb-dur:16s;--orb-delay:1s"></div>
      <div class="hero-orb-large" style="width:220px;height:220px;top:65%;left:75%;--orb-opacity:0.07;--drift-x:-20px;--drift-y:-15px;--orb-dur:20s;--orb-delay:3s"></div>

      <!-- Architectural Orbital Rings -->
      <div class="orbital-ring orbital-ring-1">
        <div class="orbit-dot" style="--orbit-r:400px;--dot-dur:22s;--dot-delay:0s;--dot-dir:normal">
          <div class="orbit-dot-inner" style="--dot-size:9px;--dot-color:rgba(139,92,246,0.95);--dot-glow:rgba(139,92,246,0.8);--dot-glow2:rgba(139,92,246,0.4);--dot-pulse:2.5s"></div>
        </div>
        <div class="orbit-dot" style="--orbit-r:400px;--dot-dur:22s;--dot-delay:-11s;--dot-dir:normal">
          <div class="orbit-dot-inner" style="--dot-size:6px;--dot-color:rgba(167,139,250,0.85);--dot-glow:rgba(167,139,250,0.7);--dot-glow2:rgba(167,139,250,0.35);--dot-pulse:3.2s"></div>
        </div>
        <div class="orbit-dot" style="--orbit-r:400px;--dot-dur:22s;--dot-delay:-5.5s;--dot-dir:normal">
          <div class="orbit-dot-inner" style="--dot-size:5px;--dot-color:rgba(99,102,241,0.9);--dot-glow:rgba(99,102,241,0.75);--dot-glow2:rgba(99,102,241,0.4);--dot-pulse:2.8s"></div>
        </div>
      </div>
      <div class="orbital-ring orbital-ring-2">
        <div class="orbit-dot" style="--orbit-r:600px;--dot-dur:35s;--dot-delay:0s;--dot-dir:reverse">
          <div class="orbit-dot-inner" style="--dot-size:7px;--dot-color:rgba(99,102,241,0.8);--dot-glow:rgba(99,102,241,0.65);--dot-glow2:rgba(99,102,241,0.3);--dot-pulse:4s"></div>
        </div>
        <div class="orbit-dot" style="--orbit-r:600px;--dot-dur:35s;--dot-delay:-17.5s;--dot-dir:reverse">
          <div class="orbit-dot-inner" style="--dot-size:5px;--dot-color:rgba(139,92,246,0.75);--dot-glow:rgba(139,92,246,0.6);--dot-glow2:rgba(139,92,246,0.3);--dot-pulse:3.5s"></div>
        </div>
      </div>

      <!-- Ambient Orbs -->
      <div class="ambient-orb" style="width:6px;height:6px;top:20%;left:15%;--orb-opacity:0.5;--drift-x:15px;--drift-y:-25px;--orb-dur:9s;--orb-delay:0s"></div>
      <div class="ambient-orb" style="width:4px;height:4px;top:60%;left:8%;--orb-opacity:0.3;--drift-x:-12px;--drift-y:20px;--orb-dur:12s;--orb-delay:2s"></div>
      <div class="ambient-orb" style="width:8px;height:8px;top:15%;left:75%;--orb-opacity:0.25;--drift-x:20px;--drift-y:-15px;--orb-dur:11s;--orb-delay:1s;--orb-blur:1px"></div>
      <div class="ambient-orb" style="width:3px;height:3px;top:75%;left:85%;--orb-opacity:0.4;--drift-x:-18px;--drift-y:-22px;--orb-dur:8s;--orb-delay:3s"></div>
      <div class="ambient-orb" style="width:5px;height:5px;top:40%;left:45%;--orb-opacity:0.2;--drift-x:10px;--drift-y:15px;--orb-dur:14s;--orb-delay:4s;--orb-blur:2px"></div>
      <div class="ambient-orb" style="width:4px;height:4px;top:85%;left:30%;--orb-opacity:0.35;--drift-x:14px;--drift-y:-18px;--orb-dur:10s;--orb-delay:1.5s"></div>
      </div><!-- /aria-hidden decorative wrapper -->

      <div class="page-container w-full relative z-10">
        <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-8 lg:gap-8 items-center">
          <!-- Text -->
          <div class="fade-in-section stagger-1 text-center lg:text-left py-16 sm:py-24 lg:py-0 lg:min-h-0 flex flex-col justify-center items-center lg:items-start lg:block">
            <h1 class="heading-editorial text-[clamp(2.2rem,7vw,3.5rem)] sm:text-[clamp(2.8rem,6vw,4rem)] lg:text-[clamp(3.5rem,4.5vw,5rem)] [text-wrap:balance]">
              <span class="block" data-i18n="hero.title1">Build Better Habits,</span>
              <span class="heading-editorial-accent gradient-text block" data-i18n="hero.title2">One Day at a Time</span>
            </h1>
            <p class="hero-subtitle mt-8 text-lg sm:text-xl text-text-secondary leading-relaxed max-w-lg mx-auto lg:mx-0 text-center lg:text-left" style="animation-delay:0.15s" data-i18n="hero.subtitle">
              AI-powered insights, goal tracking, and streaks that actually keep you motivated.
            </p>
            <div class="hero-cta-group mt-10 flex flex-col sm:flex-row items-center gap-5 justify-center lg:justify-start" style="animation-delay:0.3s">
              <CtaButton href={appUrl} breathe class="px-8 py-3.5 text-base">
                <span data-i18n="hero.cta">Get Started</span>
              </CtaButton>
              <div class="tooltip-trigger" tabindex="0" aria-describedby="android-tooltip">
                <span class="text-text-muted text-sm inline-flex items-center gap-2 cursor-default">
                  <svg class="w-4 h-4 opacity-60" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 3.658L16.8 9.99l-2.302 2.302L5.864 3.658z"/>
                  </svg>
                  <span data-i18n="hero.android">Android app coming soon</span>
                </span>
                <span class="tooltip-text" id="android-tooltip" role="tooltip" data-i18n="hero.comingSoon">Coming Soon</span>
              </div>
            </div>
          </div>

          <!-- Phone Mockup -->
          <div class="fade-in-section stagger-2 flex justify-center lg:justify-end pb-8 lg:pb-0 lg:mt-4">
            <div class="phone-3d-scene" aria-hidden="true">
            <div class="phone-hero-halo"></div>
            <div class="phone-3d-card">
              <div class="phone-3d-glow"></div>
            <div class="phone-wrapper relative">
              <div class="phone-chassis">
                <div class="phone-btn phone-btn-vol-up"></div>
                <div class="phone-btn phone-btn-vol-down"></div>
                <div class="phone-btn phone-btn-power"></div>
                <div class="phone-notch">
                  <div class="phone-notch-speaker"></div>
                  <div class="phone-notch-camera"></div>
                </div>
                <div class="phone-screen-reflection"></div>
                <div class="phone-frame w-[264px] sm:w-[284px]">
                  <div class="app-screen-scaler">
                    <div class="app-screen">
                      <div class="app-statusbar">
                        <span>9:41</span>
                        <div class="app-statusbar-right">
                          <div class="app-signal"><span></span><span></span><span></span><span></span></div>
                          <span style="font-size:11px">5G</span>
                          <div class="app-battery"><div class="app-battery-fill"></div></div>
                        </div>
                      </div>

                      <!-- Header -->
                      <div class="app-hdr">
                        <div class="app-hdr-left">
                          <img class="app-hdr-logo" src="/logo.png" alt="Orbit" width="28" height="28" loading="lazy">
                          <span class="app-hdr-title">Orbit</span>
                        </div>
                        <div class="app-hdr-bell">
                          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        </div>
                      </div>

                      <!-- Tabs -->
                      <div class="app-tabs">
                        <div class="app-tab active" data-i18n="mockup.today">Today</div>
                        <div class="app-tab" data-i18n="mockup.allHabits">All Habits</div>
                      </div>

                      <!-- Date Nav -->
                      <div class="app-datenav">
                        <div class="app-datenav-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 18l-6-6 6-6"/></svg></div>
                        <span class="app-datenav-label" data-i18n="mockup.todayLabel">Today</span>
                        <div class="app-datenav-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg></div>
                      </div>

                      <!-- AI Card -->
                      <div class="app-ai">
                        <div class="app-ai-hdr">
                          <span class="app-ai-icon">&#10024;</span>
                          <span class="app-ai-title" data-i18n="mockup.yourDay">Your Day</span>
                          <span class="app-pro">PRO</span>
                        </div>
                        <div class="app-ai-body" data-i18n="mockup.aiText">Amazing consistency! You've completed 5 of 7 habits today. Your morning routine streak is at 12 days.</div>
                      </div>

                      <div class="app-habits">
                        <div class="app-habit due">
                          <div class="app-expand"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 18l6-6-6-6"/></svg></div>
                          <div class="app-ring">
                            <svg viewBox="0 0 28 28" aria-hidden="true"><circle class="ring-bg" cx="14" cy="14" r="11"/><circle class="ring-fg" cx="14" cy="14" r="11" stroke-dasharray="69.1" stroke-dashoffset="23"/></svg>
                            <span class="app-ring-text">2/3</span>
                          </div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit1">Morning Routine</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">7:00 AM</span>
                              <span class="app-tag" style="background:#f59e0b" data-i18n="mockup.tag.wellness">Wellness</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <div class="app-sub">
                          <div class="app-sub-btn checked"><svg style="width:11px;height:11px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent"><div class="app-sub-name striked" data-i18n="mockup.sub1">Stretch (10 min)</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>
                        <div class="app-sub">
                          <div class="app-sub-btn checked"><svg style="width:11px;height:11px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent"><div class="app-sub-name striked" data-i18n="mockup.sub2">Healthy breakfast</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>
                        <div class="app-sub">
                          <div class="app-sub-btn"></div>
                          <div class="app-hcontent"><div class="app-sub-name" data-i18n="mockup.sub3">Journal (5 min)</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>

                        <div class="app-habit done">
                          <div class="app-logbtn checked"><svg style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent">
                            <div class="app-hname striked" data-i18n="mockup.habit2">Exercise</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">8:30 AM</span>
                              <span class="app-checklist-badge">&#9745; 4/4</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <div class="app-habit due">
                          <div class="app-logbtn"></div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit3">Read 30 minutes</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">2:00 PM</span>
                              <span class="app-tag" style="background:#3b82f6" data-i18n="mockup.tag.growth">Growth</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <div class="app-habit due">
                          <div class="app-logbtn"></div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit4">Meditate</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">6:00 PM</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>
                      </div>

                      <div class="app-nav">
                        <div class="app-nav-inner">
                          <div class="app-nav-item">
                            <svg class="app-nav-icon active" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                            <span class="app-nav-lbl active" data-i18n="mockup.nav.habits">Habits</span>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.chat">Chat</span>
                          </div>
                          <div class="app-fab-wrap">
                            <div class="app-fab"><svg viewBox="0 0 24 24" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.calendar">Calendar</span>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.profile">Profile</span>
                          </div>
                        </div>
                      </div>
                      <div class="app-homebar"></div>
                    </div>
                  </div>
              </div>
              </div>
            </div>
            </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Gradient bridge: smooths the hero-to-features seam -->
    <div class="hero-features-bridge"></div>

    <!-- Features + Platforms: shared planet background -->
    <div class="dual-section-wrap">
      <!-- Shared background -->
      <div class="shared-dot-grid"></div>
      <div class="shared-planet"></div>
      <!-- Stars scattered across both sections -->
      <Sparkles sparkles={dualSectionSparkles} />
      <div class="shared-vignette"></div>

    <!-- Features Section -->
    <section id="features" class="features-bg py-14 sm:py-20 lg:py-24">

      <div class="page-container">
        <div class="fade-in-section mb-10 text-center lg:text-left lg:max-w-2xl">
          <span class="tech-label mb-4 inline-flex" data-i18n="features.label">Features</span>
          <h2 class="heading-editorial text-2xl sm:text-3xl lg:text-[2.25rem] xl:text-[2.75rem]">
            <span data-i18n="features.title1">Everything you need to build</span>
            <span class="heading-editorial-accent gradient-text" data-i18n="features.title2"> lasting habits</span>
          </h2>
        </div>

        <div class="feature-grid-6">

          <!-- Card 1: Smart Scheduling -->
          <NeonCard stagger={1}>
            <div class="neon-feature-icon w-10 h-10 rounded-xl flex items-center justify-center mb-4">
