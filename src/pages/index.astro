---
import Layout from "../layouts/Layout.astro";
import Cta from "../components/Cta.astro";
import Features from "../components/Features.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import Platforms from "../components/Platforms.astro";

const appUrl = import.meta.env.PUBLIC_APP_URL || "https://app.useorbit.org";
const googlePlayUrl = "https://play.google.com/store/apps/details?id=org.useorbit.app";
---

<Layout>
  <a href="#main-content" class="skip-to-content">Skip to content</a>
  <Header appUrl={appUrl} />
  <main id="main-content">
    <Hero appUrl={appUrl} googlePlayUrl={googlePlayUrl} />
    <Features />
    <Platforms appUrl={appUrl} googlePlayUrl={googlePlayUrl} />
    <Cta appUrl={appUrl} />
  </main>
  <Footer appUrl={appUrl} />
</Layout>

<script>
  import "../scripts/counter";
  import "../scripts/header-scroll";
  import "../scripts/i18n";
  import "../scripts/reveal";
  import "../scripts/tilt";
</script>
