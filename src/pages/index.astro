---
import Layout from "../layouts/Layout.astro";

const appUrl = import.meta.env.PUBLIC_APP_URL || "https://app.useorbit.org";
---

<Layout>
  <!-- Scroll Progress -->
  <div id="scroll-progress" class="scroll-progress"></div>

  <!-- Header -->
  <header id="site-header" class="header-glass fixed top-0 left-0 right-0 z-50">
    <nav class="max-w-7xl mx-auto px-6 sm:px-8 h-16 flex items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 group logo-hover">
        <img src="/logo.png" alt="Orbit" class="w-8 h-8 rounded-lg transition-all group-hover:drop-shadow-[0_0_8px_rgba(139,92,246,0.4)]" />
        <span class="text-lg font-bold text-text-primary">Orbit</span>
      </a>
      <div class="flex items-center gap-5">
        <button
          id="lang-toggle"
          class="text-sm text-text-muted hover:text-text-primary transition-colors cursor-pointer"
          aria-label="Switch language"
        >
          <span id="lang-label" class="border-b border-text-muted/30 pb-0.5">EN</span>
        </button>
        <a
          href={appUrl}
          class="text-sm font-semibold px-5 py-2 rounded-full border border-primary/30 text-primary hover:bg-primary hover:text-white transition-all duration-300"
          data-i18n="header.cta"
        >
          Go to Orbit
        </a>
      </div>
    </nav>
  </header>

  <main>
    <!-- Hero Section -->
    <section class="hero-section relative lg:min-h-screen lg:flex lg:items-center pt-16 pb-8 sm:pb-16 overflow-hidden">
      <!-- Architectural Orbital Rings -->
      <div class="orbital-ring orbital-ring-1"></div>
      <div class="orbital-ring orbital-ring-2"></div>

      <!-- Ambient Floating Orbs -->
      <div class="ambient-orb" style="width:6px;height:6px;top:20%;left:15%;--orb-opacity:0.5;--drift-x:15px;--drift-y:-25px;--orb-dur:9s;--orb-delay:0s"></div>
      <div class="ambient-orb" style="width:4px;height:4px;top:60%;left:8%;--orb-opacity:0.3;--drift-x:-12px;--drift-y:20px;--orb-dur:12s;--orb-delay:2s"></div>
      <div class="ambient-orb" style="width:8px;height:8px;top:15%;left:75%;--orb-opacity:0.25;--drift-x:20px;--drift-y:-15px;--orb-dur:11s;--orb-delay:1s;--orb-blur:1px"></div>
      <div class="ambient-orb" style="width:3px;height:3px;top:75%;left:85%;--orb-opacity:0.4;--drift-x:-18px;--drift-y:-22px;--orb-dur:8s;--orb-delay:3s"></div>
      <div class="ambient-orb" style="width:5px;height:5px;top:40%;left:45%;--orb-opacity:0.2;--drift-x:10px;--drift-y:15px;--orb-dur:14s;--orb-delay:4s;--orb-blur:2px"></div>
      <div class="ambient-orb" style="width:4px;height:4px;top:85%;left:30%;--orb-opacity:0.35;--drift-x:14px;--drift-y:-18px;--orb-dur:10s;--orb-delay:1.5s"></div>

      <div class="max-w-7xl mx-auto px-6 sm:px-8 w-full relative z-10">
        <div class="grid lg:grid-cols-[1.2fr_0.8fr] gap-8 lg:gap-8 items-center">
          <!-- Text -->
          <div class="fade-in-section stagger-1 text-center lg:text-left min-h-[calc(100dvh-6rem)] lg:min-h-0 flex flex-col justify-center items-center lg:items-start lg:block">
            <h1 class="heading-editorial text-[clamp(2.2rem,7vw,3.5rem)] sm:text-[clamp(2.8rem,8vw,5rem)] lg:text-[clamp(4rem,5.5vw,5.5rem)]">
              <span class="block" data-i18n="hero.title1">Build Better Habits,</span>
              <span class="heading-rule"></span>
              <span class="heading-editorial-accent gradient-text block" data-i18n="hero.title2">One Day at a Time</span>
            </h1>
            <p class="hero-subtitle mt-8 text-lg sm:text-xl text-text-secondary leading-relaxed max-w-lg mx-auto lg:mx-0" style="animation-delay:0.8s" data-i18n="hero.subtitle">
              Track your daily habits, build streaks, and get AI-powered insights to stay on top of your goals.
            </p>
            <div class="hero-cta-group mt-10 flex flex-col sm:flex-row items-center gap-5 justify-center lg:justify-start" style="animation-delay:1s">
              <a
                href={appUrl}
                class="btn-magnetic btn-glow btn-shimmer bg-primary hover:bg-primary-hover text-white font-semibold px-8 py-3.5 rounded-full text-base transition-colors inline-flex items-center gap-2 relative"
                data-magnetic
              >
                <span data-i18n="hero.cta">Get Started</span>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
                <span class="btn-ring rounded-full"></span>
              </a>
              <div class="tooltip-trigger">
                <span class="text-text-muted text-sm inline-flex items-center gap-2 cursor-default">
                  <svg class="w-4 h-4 opacity-60" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 3.658L16.8 9.99l-2.302 2.302L5.864 3.658z"/>
                  </svg>
                  <span data-i18n="hero.android">Download for Android</span>
                </span>
                <span class="tooltip-text" data-i18n="hero.comingSoon">Coming Soon</span>
              </div>
            </div>
          </div>

          <!-- Phone Mockup -->
          <div class="fade-in-section stagger-2 flex justify-center lg:justify-end">
            <div class="phone-wrapper relative">
              <div class="phone-border p-[1.5px] rounded-[3rem] shadow-phone">
                <div class="phone-frame rounded-[2.9rem] w-[280px] sm:w-[300px]">
                  <div class="app-screen-scaler">
                    <div class="app-screen">
                      <!-- Status Bar -->
                      <div class="app-statusbar">
                        <span>9:41</span>
                        <div class="app-statusbar-right">
                          <div class="app-signal"><span></span><span></span><span></span><span></span></div>
                          <span style="font-size:11px">5G</span>
                          <div class="app-battery"><div class="app-battery-fill"></div></div>
                        </div>
                      </div>

                      <!-- Header -->
                      <div class="app-hdr">
                        <div class="app-hdr-left">
                          <img class="app-hdr-logo" src="/logo.png" alt="Orbit">
                          <span class="app-hdr-title">Orbit</span>
                        </div>
                        <div class="app-hdr-bell">
                          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                        </div>
                      </div>

                      <!-- Tabs -->
                      <div class="app-tabs">
                        <div class="app-tab active" data-i18n="mockup.today">Today</div>
                        <div class="app-tab" data-i18n="mockup.allHabits">All Habits</div>
                      </div>

                      <!-- Date Nav -->
                      <div class="app-datenav">
                        <div class="app-datenav-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg></div>
                        <span class="app-datenav-label" data-i18n="mockup.todayLabel">Today</span>
                        <div class="app-datenav-arrow"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg></div>
                      </div>

                      <!-- AI Card -->
                      <div class="app-ai">
                        <div class="app-ai-hdr">
                          <span class="app-ai-icon">&#10024;</span>
                          <span class="app-ai-title" data-i18n="mockup.yourDay">Your Day</span>
                          <span class="app-pro">PRO</span>
                        </div>
                        <div class="app-ai-body" data-i18n="mockup.aiText">Great momentum! You've completed 3 of 7 habits. Your morning routine streak is at 12 days.</div>
                      </div>

                      <!-- Habit List -->
                      <div class="app-habits">
                        <!-- Morning Routine -->
                        <div class="app-habit due">
                          <div class="app-expand"><svg viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg></div>
                          <div class="app-ring">
                            <svg viewBox="0 0 28 28"><circle class="ring-bg" cx="14" cy="14" r="11"/><circle class="ring-fg" cx="14" cy="14" r="11" stroke-dasharray="69.1" stroke-dashoffset="23"/></svg>
                            <span class="app-ring-text">2/3</span>
                          </div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit1">Morning Routine</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">7:00 AM</span>
                              <span class="app-tag" style="background:#f59e0b" data-i18n="mockup.tag.wellness">Wellness</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <!-- Sub-habits -->
                        <div class="app-sub">
                          <div class="app-sub-btn checked"><svg style="width:11px;height:11px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent"><div class="app-sub-name striked" data-i18n="mockup.sub1">Stretch (10 min)</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>
                        <div class="app-sub">
                          <div class="app-sub-btn checked"><svg style="width:11px;height:11px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent"><div class="app-sub-name striked" data-i18n="mockup.sub2">Healthy breakfast</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>
                        <div class="app-sub">
                          <div class="app-sub-btn"></div>
                          <div class="app-hcontent"><div class="app-sub-name" data-i18n="mockup.sub3">Journal (5 min)</div><div class="app-sub-meta" data-i18n="mockup.freq.daily">Daily</div></div>
                        </div>

                        <!-- Exercise (completed) -->
                        <div class="app-habit done">
                          <div class="app-logbtn checked"><svg style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                          <div class="app-hcontent">
                            <div class="app-hname striked" data-i18n="mockup.habit2">Exercise</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">8:30 AM</span>
                              <span class="app-checklist-badge">&#9745; 4/4</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <!-- Read 30 minutes -->
                        <div class="app-habit due">
                          <div class="app-logbtn"></div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit3">Read 30 minutes</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">2:00 PM</span>
                              <span class="app-tag" style="background:#3b82f6" data-i18n="mockup.tag.growth">Growth</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>

                        <!-- Meditate -->
                        <div class="app-habit due">
                          <div class="app-logbtn"></div>
                          <div class="app-hcontent">
                            <div class="app-hname" data-i18n="mockup.habit4">Meditate</div>
                            <div class="app-hmeta">
                              <span class="app-freq" data-i18n="mockup.freq.daily">Daily</span>
                              <span class="app-time">6:00 PM</span>
                            </div>
                          </div>
                          <div class="app-kebab"><svg viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></div>
                        </div>
                      </div>

                      <!-- Bottom Nav -->
                      <div class="app-nav">
                        <div class="app-nav-inner">
                          <div class="app-nav-item">
                            <svg class="app-nav-icon active" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
                            <span class="app-nav-lbl active" data-i18n="mockup.nav.habits">Habits</span>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.chat">Chat</span>
                          </div>
                          <div class="app-fab-wrap">
                            <div class="app-fab"><svg viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg></div>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.calendar">Calendar</span>
                          </div>
                          <div class="app-nav-item">
                            <svg class="app-nav-icon" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                            <span class="app-nav-lbl" data-i18n="mockup.nav.profile">Profile</span>
                          </div>
                        </div>
                      </div>
                      <div class="app-homebar"></div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section Divider -->
    <div class="section-divider fade-in-section"></div>

    <!-- Features Section -->
    <section id="features" class="py-16 sm:py-28 lg:py-36">
      <div class="max-w-7xl mx-auto px-6 sm:px-8">
        <div class="fade-in-section mb-16 text-center lg:text-left lg:max-w-2xl">
          <span class="text-xs font-extrabold uppercase tracking-[0.2em] text-primary mb-4 block font-sans" data-i18n="features.label">Features</span>
          <h2 class="heading-editorial text-3xl sm:text-4xl lg:text-5xl xl:text-6xl">
            <span data-i18n="features.title1">Everything you need to build</span>
            <span class="heading-editorial-accent gradient-text" data-i18n="features.title2"> lasting habits</span>
          </h2>
        </div>

        <div class="bento-grid">
          <!-- Smart Scheduling - Wide -->
          <div class="fade-in-section stagger-1 glass-panel glow-border-hover rounded-2xl p-8 bento-wide flex flex-col justify-between">
            <div>
              <div class="feature-icon-wrap w-12 h-12 rounded-xl bg-primary-a10 flex items-center justify-center mb-6">
                <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><circle cx="8" cy="15" r="1" fill="currentColor"/><circle cx="12" cy="15" r="1" fill="currentColor"/><circle cx="16" cy="15" r="1" fill="currentColor"/></svg>
              </div>
              <h3 class="text-xl font-bold text-text-primary mb-2 font-sans" data-i18n="features.scheduling.title">Smart Scheduling</h3>
              <p class="text-text-secondary text-sm leading-relaxed max-w-md" data-i18n="features.scheduling.desc">Set daily, weekly, or custom frequencies. Orbit calculates exactly when each habit is due.</p>
            </div>
            <!-- Mini week dots -->
            <div class="flex gap-2 mt-8">
              <span class="w-8 h-8 rounded-lg bg-primary/20 flex items-center justify-center text-xs font-bold text-primary/60">M</span>
              <span class="w-8 h-8 rounded-lg bg-primary/40 flex items-center justify-center text-xs font-bold text-primary">T</span>
              <span class="w-8 h-8 rounded-lg bg-primary flex items-center justify-center text-xs font-bold text-white">W</span>
              <span class="w-8 h-8 rounded-lg bg-primary/20 flex items-center justify-center text-xs font-bold text-primary/60">T</span>
              <span class="w-8 h-8 rounded-lg bg-primary/40 flex items-center justify-center text-xs font-bold text-primary">F</span>
              <span class="w-8 h-8 rounded-lg border border-border-light flex items-center justify-center text-xs font-bold text-text-muted">S</span>
              <span class="w-8 h-8 rounded-lg border border-border-light flex items-center justify-center text-xs font-bold text-text-muted">S</span>
            </div>
          </div>

          <!-- AI Insights - Tall -->
          <div class="fade-in-section stagger-2 glass-panel glow-border-hover rounded-2xl p-8 bento-tall flex flex-col">
            <div class="feature-icon-wrap w-12 h-12 rounded-xl bg-accent-blue flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 2l1.09 3.26L16.36 6l-2.6 2.17L14.36 12 12 9.92 9.64 12l.6-3.83L7.64 6l3.27-.74Z"/><path d="M5 18h14"/><path d="M7 22h10"/></svg>
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-2 font-sans" data-i18n="features.ai.title">AI Insights</h3>
            <p class="text-text-secondary text-sm leading-relaxed mb-6" data-i18n="features.ai.desc">Get personalized daily summaries and routine analysis powered by AI.</p>
            <!-- Mock AI bubble -->
            <div class="mt-auto rounded-xl bg-surface/80 border border-border-light p-4">
              <div class="flex items-center gap-2 mb-2">
                <span class="text-primary text-sm">&#10024;</span>
                <span class="text-xs font-bold text-text-secondary uppercase tracking-wider">AI Summary</span>
              </div>
              <p class="text-xs text-text-muted leading-relaxed typing-cursor">"Your morning routine streak is at 12 days. Keep it going!"</p>
            </div>
          </div>

          <!-- Streak Tracking -->
          <div class="fade-in-section stagger-3 glass-panel glow-border-hover rounded-2xl p-8">
            <div class="feature-icon-wrap w-12 h-12 rounded-xl bg-accent-orange flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-orange-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 22c-4.97 0-9-2.69-9-6v-.01C3 12.13 6.16 9.21 8.14 7.14c.49-.51 1.28-.2 1.33.5.11 1.46.66 2.67 1.53 3.36.23-2.08 1.17-4.14 2.81-6.18.37-.46 1.07-.38 1.32.16C16.48 7.92 21 12.14 21 15.99v.01c0 3.31-4.03 6-9 6Z"/></svg>
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-2 font-sans" data-i18n="features.streaks.title">Streak Tracking</h3>
            <p class="text-text-secondary text-sm leading-relaxed" data-i18n="features.streaks.desc">Watch your streaks grow. Visual progress that keeps you motivated day after day.</p>
            <div class="mt-6 flex items-baseline gap-1">
              <span class="streak-counter text-4xl font-extrabold text-primary font-sans" data-target="12">0</span>
              <span class="text-sm text-text-muted font-semibold">days</span>
            </div>
          </div>

          <!-- Sub-Habits -->
          <div class="fade-in-section stagger-4 glass-panel glow-border-hover rounded-2xl p-8">
            <div class="feature-icon-wrap w-12 h-12 rounded-xl bg-accent-green flex items-center justify-center mb-6">
              <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M12 3v18"/><path d="M8 8l4-4 4 4"/><path d="M8 16h8"/><path d="M6 12h12"/></svg>
            </div>
            <h3 class="text-xl font-bold text-text-primary mb-2 font-sans" data-i18n="features.subhabits.title">Sub-Habits</h3>
            <p class="text-text-secondary text-sm leading-relaxed" data-i18n="features.subhabits.desc">Break big habits into smaller steps. Complete sub-tasks to build momentum.</p>
            <!-- Visual nesting -->
            <div class="mt-6 space-y-2 text-xs font-semibold">
              <div class="flex items-center gap-2 text-text-secondary"><span class="w-3 h-3 rounded-full bg-primary/40"></span> Morning Routine</div>
              <div class="flex items-center gap-2 text-text-muted ml-5"><span class="w-2 h-2 rounded-full bg-primary"></span> Stretch</div>
              <div class="flex items-center gap-2 text-text-muted ml-5"><span class="w-2 h-2 rounded-full bg-primary"></span> Breakfast</div>
              <div class="flex items-center gap-2 text-text-muted ml-5"><span class="w-2 h-2 rounded-full border border-primary/40"></span> Journal</div>
            </div>
          </div>

          <!-- Calendar + Multi-Language - Full Width -->
          <div class="fade-in-section stagger-5 glass-panel glow-border-hover rounded-2xl p-8 bento-full">
