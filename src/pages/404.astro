---
import Layout from "../layouts/Layout.astro";
import PillButton from "../components/PillButton.astro";
import SatelliteGlyph from "../components/SatelliteGlyph.astro";
---

<Layout
  title="Orbit - Page Not Found"
  description="The page you're looking for doesn't exist."
  noindex
>
  <main class="flex min-h-dvh flex-col items-center justify-center px-6 text-center">
    <SatelliteGlyph size={96} class="satellite-bob" />
    <h1 class="t-display mt-8">404</h1>
    <p class="t-body mt-3 max-w-[400px] text-fg-2">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <div class="mt-8">
      <PillButton href="/" glow>Back to Home</PillButton>
    </div>
  </main>
</Layout>
