---
interface Props {
  size?: number;
  class?: string;
}

const { size = 96, class: className = "" } = Astro.props;
---

<svg
  width={size}
  height={size}
  viewBox="0 0 96 96"
  fill="none"
  aria-hidden="true"
  class={className}
>
  <circle cx="34" cy="34" r="19" stroke="var(--color-fg-4)" stroke-width="2.5"></circle>
  <path
    d="M34 21 a13 13 0 0 1 13 13"
    stroke="var(--color-primary)"
    stroke-width="3"
    stroke-linecap="round"></path>
  <circle cx="34" cy="34" r="5" fill="var(--color-fg-3)"></circle>
  <rect
    x="52"
    y="52"
    width="22"
    height="13"
    rx="2.5"
    transform="rotate(45 63 58)"
    stroke="var(--color-fg-4)"
    stroke-width="2.5"></rect>
  <path d="M63 70 L63 84" stroke="var(--color-fg-4)" stroke-width="2.5" stroke-linecap="round"
  ></path>
  <path d="M56 84 L70 84" stroke="var(--color-fg-4)" stroke-width="2.5" stroke-linecap="round"
  ></path>
  <circle cx="74" cy="22" r="2" fill="color-mix(in srgb, var(--color-primary) 55%, white)"></circle>
  <circle cx="20" cy="68" r="1.6" fill="color-mix(in srgb, var(--color-primary) 55%, white)"
  ></circle>
</svg>
