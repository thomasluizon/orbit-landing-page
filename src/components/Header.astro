---
import { Image } from "astro:assets";
import PillButton from "./PillButton.astro";
import logoNoBg from "../assets/logo-no-bg.png";

interface Props {
  appUrl: string;
}

const { appUrl } = Astro.props;
---

<header id="site-header" class="fixed inset-x-0 top-0 z-50">
  <nav aria-label="Main" class="page-container flex h-16 items-center justify-between">
    <a href="/" class="flex items-center gap-2.5">
      <Image
        src={logoNoBg}
        alt="Orbit"
        width={32}
        height={32}
        fetchpriority="high"
        class="h-8 w-8"
      />
      <span class="font-sans text-[18px] font-medium text-fg-1">Orbit</span>
    </a>
    <div class="flex items-center gap-4">
      <button
        id="lang-toggle"
        class="flex min-h-[44px] min-w-[44px] cursor-pointer items-center justify-center font-sans text-[14px] text-fg-3 transition-[color] duration-[var(--duration-fast)] ease-standard hover:text-fg-1"
        aria-label="Switch to Portuguese"
      >
        <span id="lang-label" class="border-b border-hairline-strong pb-0.5">EN</span>
      </button>
      <PillButton href={appUrl} variant="ghost" size="sm">
        <span data-i18n="header.cta">Get Started</span>
      </PillButton>
    </div>
  </nav>
</header>

<style>
  #site-header {
    transition:
      background-color var(--duration-normal) var(--ease-standard),
      box-shadow var(--duration-normal) var(--ease-standard);
  }

  #site-header.scrolled {
    background-color: var(--color-bg);
    box-shadow: inset 0 -1px 0 var(--color-hairline);
  }
</style>
