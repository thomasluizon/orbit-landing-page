---
import { Check } from "@lucide/astro";
import MediaSlot from "./MediaSlot.astro";

const points = ["mcp.point1", "mcp.point2", "mcp.point3"];
const fallbackPoints = [
  "OAuth 2.0 or scoped, hashed API keys",
  "Read-only or full access, revocable anytime",
  "Scoped to your account, nothing else",
];
---

<section id="mcp" class="py-20 sm:py-24">
  <div class="page-container grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
    <div class="reveal">
      <p class="t-eyebrow" data-i18n="mcp.eyebrow">Model Context Protocol</p>
      <h2 class="t-display mt-3 max-w-[440px] [text-wrap:balance]">
        <span data-i18n="mcp.title1">Run your habits from</span>
        <span class="text-primary" data-i18n="mcp.title2">Claude or ChatGPT</span>
      </h2>
      <p class="t-body mt-4 max-w-[460px] text-fg-2 [text-wrap:pretty]" data-i18n="mcp.desc">
        Orbit exposes a full MCP server, so your favorite AI assistant can create habits, log
        progress, and check your streaks without leaving your chat.
      </p>

      <div class="mt-7 flex gap-8">
        <div>
          <div
            class="font-display text-[34px] leading-none font-bold tracking-[-0.02em] text-fg-1 [font-variant-numeric:tabular-nums]"
            data-i18n="mcp.stat1Value"
          >
            79
          </div>
          <div class="t-secondary mt-1 text-fg-3" data-i18n="mcp.stat1Label">MCP tools</div>
        </div>
        <div style="box-shadow: inset 1px 0 0 var(--color-hairline);" class="pl-8">
          <div
            class="font-display text-[34px] leading-none font-bold tracking-[-0.02em] text-fg-1 [font-variant-numeric:tabular-nums]"
            data-i18n="mcp.stat2Value"
          >
            15
          </div>
          <div class="t-secondary mt-1 text-fg-3" data-i18n="mcp.stat2Label">tool categories</div>
        </div>
      </div>

      <ul class="mt-7 flex flex-col gap-3">
        {
          points.map((key, index) => (
            <li class="flex items-center gap-3">
              <span
                class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full"
                style="background: rgba(var(--primary-rgb), 0.15);"
              >
                <Check size={13} stroke-width={2.4} class="text-primary" />
              </span>
              <span class="font-sans text-[14px] text-fg-2" data-i18n={key}>
                {fallbackPoints[index]}
              </span>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="reveal">
      <MediaSlot
        labelKey="mcp.caption"
        label="Ask your assistant to log a habit. It just works."
        ratio="4 / 3"
      >
        <div class="w-full max-w-[380px]">
          <div class="flex justify-end">
            <div
              class="max-w-[75%] rounded-[16px] rounded-br-[6px] bg-primary px-4 py-2.5 font-sans text-[13.5px] leading-[1.45] text-fg-on-primary"
            >
              <span data-i18n="mcp.chat.user">Log my run for today</span>
            </div>
          </div>

          <div class="mt-3 flex justify-start">
            <div
              class="max-w-[85%] rounded-[16px] rounded-bl-[6px] bg-bg-card px-4 py-3"
              style="box-shadow: inset 0 0 0 1px var(--color-hairline);"
            >
              <div
                class="inline-flex items-center gap-1.5 rounded-md bg-bg-sunk px-2 py-1 font-mono text-[10.5px] tracking-[0.02em] text-fg-3"
              >
                <span class="h-1.5 w-1.5 rounded-full bg-status-frozen" aria-hidden="true"></span>
                Orbit · log_habit
              </div>
              <p
                class="mt-2 font-sans text-[13.5px] leading-[1.45] text-fg-1"
                data-i18n="mcp.chat.reply"
              >
                Done. Your running streak is now 6 days.
              </p>
            </div>
          </div>
        </div>
      </MediaSlot>
    </div>
  </div>
</section>
