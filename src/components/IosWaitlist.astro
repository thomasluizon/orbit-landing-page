---
import { Apple } from "@lucide/astro";
---

<section id="ios" class="py-20 sm:py-24">
  <div class="page-container">
    <div
      class="relative overflow-hidden rounded-[24px] px-6 py-12 text-center sm:px-12 sm:py-16"
      style="background: rgba(var(--primary-rgb), 0.06); box-shadow: inset 0 0 0 1px var(--color-hairline);"
    >
      <div
        class="pointer-events-none absolute inset-x-0 top-0 h-[220px]"
        style="background: var(--gradient-header);"
        aria-hidden="true"
      >
      </div>

      <div class="reveal relative mx-auto max-w-[520px]">
        <span
          class="inline-flex items-center gap-2 rounded-full bg-bg-sunk px-3 py-1.5 font-mono text-[11px] tracking-[0.02em] text-fg-2"
          style="box-shadow: inset 0 0 0 1px var(--color-hairline);"
        >
          <Apple size={13} class="text-fg-1" />
          <span data-i18n="ios.eyebrow">Coming soon</span>
        </span>
        <h2 class="t-display mt-5 [text-wrap:balance]" data-i18n="ios.title">
          Orbit is coming to iPhone
        </h2>
        <p
          class="t-body mx-auto mt-4 max-w-[420px] text-fg-2 [text-wrap:pretty]"
          data-i18n="ios.desc"
        >
          The iOS app is in the works. Leave your email and we'll tell you the moment it's ready.
          Double opt-in, no spam.
        </p>

        <form
          id="waitlist-form"
          novalidate
          class="mx-auto mt-8 flex max-w-[440px] flex-col gap-3 sm:flex-row"
        >
          <label for="waitlist-email" class="sr-only" data-i18n="ios.placeholder">
            you@example.com
          </label>
          <input
            id="waitlist-email"
            type="email"
            name="email"
            autocomplete="email"
            required
            placeholder="you@example.com"
            data-i18n-placeholder="ios.placeholder"
            class="min-h-[48px] flex-1 rounded-full bg-bg-field px-5 font-sans text-[15px] text-fg-1 placeholder:text-fg-4"
            style="box-shadow: inset 0 0 0 1px var(--color-hairline-strong);"
          />
          <button
            id="waitlist-submit"
            type="submit"
            class="inline-flex min-h-[48px] cursor-pointer items-center justify-center rounded-full bg-primary px-[26px] font-sans text-[15px] font-medium text-fg-on-primary shadow-[var(--primary-glow)] transition-[background-color,box-shadow,transform] duration-[var(--duration-fast)] ease-standard hover:bg-primary-pressed hover:shadow-[var(--primary-glow-hover)] active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-70"
          >
            <span id="waitlist-submit-label" data-i18n="ios.button">Notify me</span>
          </button>
        </form>

        <p
          id="waitlist-status"
          role="status"
          aria-live="polite"
          class="mt-4 min-h-[20px] font-sans text-[13.5px]"
        >
        </p>
        <p class="mt-2 font-sans text-[12.5px] text-fg-4" data-i18n="ios.privacy">
          We'll only email you about the iOS launch.
        </p>
      </div>
    </div>
  </div>
</section>
