---
import { Monitor, Smartphone } from "@lucide/astro";
import PillButton from "./PillButton.astro";

interface Props {
  appUrl: string;
  googlePlayUrl: string;
}

const { appUrl, googlePlayUrl } = Astro.props;
---

<section id="platforms" class="py-20 sm:py-24">
  <div class="page-container">
    <h2 class="t-display reveal max-w-[560px]">
      <span data-i18n="platforms.title1">Available on</span><span data-i18n="platforms.title2">
        web &amp; mobile</span
      >
    </h2>
    <p class="t-body reveal mt-3 max-w-[460px] text-fg-2" data-i18n="platforms.subtitle">
      Access your habits from any device, anytime.
    </p>

    <div class="reveal-stagger mt-10 grid gap-4 md:grid-cols-2">
      <div
        class="flex flex-col rounded-[18px] bg-bg-card p-7"
        style="box-shadow: inset 0 0 0 1px var(--color-hairline);"
      >
        <div class="flex items-center gap-3">
          <Monitor size={22} stroke-width={1.8} class="text-fg-2" />
          <h3 class="t-h2" data-i18n="platforms.web.title">Web App</h3>
        </div>
        <p
          class="mt-3 mb-7 font-sans text-[14px] leading-[1.55] text-fg-3"
          data-i18n="platforms.web.desc"
        >
          Access Orbit from any browser. Your habits sync across all your devices.
        </p>
        <PillButton href={appUrl} size="sm" class="mt-auto w-full">
          <span data-i18n="platforms.web.cta">Open Web App</span>
        </PillButton>
      </div>

      <div
        class="flex flex-col rounded-[18px] bg-bg-card p-7"
        style="box-shadow: inset 0 0 0 1px var(--color-hairline);"
      >
        <div class="flex items-center gap-3">
          <Smartphone size={22} stroke-width={1.8} class="text-fg-2" />
          <h3 class="t-h2" data-i18n="platforms.android.title">Android</h3>
          <span
            class="ml-auto rounded-full px-[9px] py-[3px] font-sans text-[10.5px] font-semibold tracking-[0.06em] text-fg-1 uppercase"
            style="background: rgba(var(--primary-rgb), 0.15);"
            data-i18n="platforms.android.badge"
          >
            Available Now
          </span>
        </div>
        <p
          class="mt-3 mb-7 font-sans text-[14px] leading-[1.55] text-fg-3"
          data-i18n="platforms.android.desc"
        >
          Take Orbit with you. Track habits on the go with our native Android app.
        </p>
        <PillButton
          href={googlePlayUrl}
          variant="ghost"
          size="sm"
          external
          ariaLabel="Open Orbit on Google Play"
          class="mt-auto w-full"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M3.609 1.814L13.792 12 3.61 22.186a.996.996 0 0 1-.61-.92V2.734a1 1 0 0 1 .609-.92zm10.89 10.893l2.302 2.302-10.937 6.333 8.635-8.635zm3.199-3.199l2.302 2.302a1 1 0 0 1 0 1.38l-2.302 2.302L15.396 12l2.302-2.492zM5.864 3.658L16.8 9.99l-2.302 2.302L5.864 3.658z"
            ></path>
          </svg>
          <span data-i18n="platforms.android.cta">Get it on Google Play</span>
        </PillButton>
      </div>
    </div>
  </div>
</section>
