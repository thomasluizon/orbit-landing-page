---
import { Image } from "astro:assets";
import logoNoBg from "../assets/logo-no-bg.png";

interface Props {
  appUrl: string;
}

const { appUrl } = Astro.props;
---

<footer class="py-7" style="box-shadow: inset 0 1px 0 var(--color-hairline);">
  <div class="page-container flex flex-col items-center justify-between gap-4 sm:flex-row">
    <div class="flex items-center gap-2.5">
      <Image src={logoNoBg} alt="Orbit" width={24} height={24} loading="lazy" class="h-6 w-6" />
      <span class="font-sans text-[14px] font-medium text-fg-1">Orbit</span>
    </div>
    <div class="flex items-center gap-5">
      <a
        href={`${appUrl}/privacy`}
        class="font-sans text-[14px] text-fg-3 transition-[color] duration-[var(--duration-fast)] ease-standard hover:text-fg-1"
        data-i18n="footer.privacy"
      >
        Privacy Policy
      </a>
      <span class="t-meta" data-i18n="footer.text">Orbit · © 2026</span>
    </div>
  </div>
</footer>
