---
import { Font } from "astro:assets";
import Analytics from "@vercel/analytics/astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  extraJsonLd?: Record<string, unknown>;
}

const {
  title = "Orbit - The habit tracker you can talk to",
  description = "Orbit pairs a serious habit tracker with Astra, an AI coach that logs your habits and reads your real streaks. Connect Claude or ChatGPT over MCP. Free to start, 7-day Pro trial, no card.",
  noindex = false,
  extraJsonLd,
} = Astro.props;

const ogImage = "/og-image.png";
const siteUrl = Astro.site?.origin || "https://useorbit.org";
const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const googlePlayUrl = "https://play.google.com/store/apps/details?id=org.useorbit.app";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      name: "Orbit",
      url: siteUrl,
      logo: `${siteUrl}/logo.png`,
    },
    {
      "@type": "WebSite",
      name: "Orbit",
      url: siteUrl,
    },
    {
      "@type": "SoftwareApplication",
      name: "Orbit",
      applicationCategory: "LifestyleApplication",
      operatingSystem: "Web",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      description: description,
    },
    {
      "@type": "MobileApplication",
      name: "Orbit",
      applicationCategory: "LifestyleApplication",
      operatingSystem: "Android",
      offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
      installUrl: googlePlayUrl,
      description: description,
    },
  ],
};
---

<!doctype html>
<html lang="en" style="color-scheme: dark only">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="dark only" />
    <meta name="theme-color" content="#020618" />
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Orbit" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />
    <meta name="twitter:site" content="@useorbit" />

    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="icon" type="image/png" href="/logo.png" />
    <link rel="canonical" href={canonicalUrl} />

    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    {
      extraJsonLd && (
        <script is:inline type="application/ld+json" set:html={JSON.stringify(extraJsonLd)} />
      )
    }

    <Font cssVariable="--font-rubik" preload />
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-roboto" />

    <noscript>
      <style>
        .reveal {
          opacity: 1;
          transform: none;
        }
      </style>
    </noscript>

    <title>{title}</title>
  </head>
  <body class="bg-bg text-fg-1 font-sans antialiased">
    <slot />
    <Analytics />
  </body>
</html>
